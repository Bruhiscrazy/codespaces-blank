local function getDeviceType()
    local viewport = workspace.CurrentCamera.ViewportSize
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
        if viewport.X < 700 then
            return "Mobile"
        else
            return "Tablet"
        end
    end
    return "Desktop"
end

