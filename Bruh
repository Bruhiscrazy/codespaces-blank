                        currentKey = input.KeyCode
                        UpdateKeyDisplay()
                        KeybindBtn.TextColor3 = SelectedTheme.Text
                        pcall(callback, currentKey)
                    end

                    if not gameProcessed and input.KeyCode == currentKey and not listening then
                        pcall(callback, currentKey)
                    end
                end)

                return {
                    Set = function(key)
                        currentKey = key
                        UpdateKeyDisplay()
                    end,
                    Get = function() return currentKey end,
                }
            end

            function SectionObj:MakeColorPicker(config)
                config = config or {}
                local pickerName = config.Name or "Color Picker"
                local default = config.Default or Color3.fromRGB(255, 255, 255)
                local callback = config.Callback or function() end

                local PickerFrame = CreateInstance("Frame", {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BackgroundTransparency = 0.95,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 0, 0, 55),
                    Parent = SectionContent,
                    ZIndex = 7,
                })
                RoundCorners(PickerFrame, 8)

                local PickerLabel = CreateInstance("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -70, 0, 18),
                    Position = UDim2.new(0, 12, 0, 8),
                    Text = pickerName,
                    TextColor3 = SelectedTheme.Text,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = PickerFrame,
                    ZIndex = 8,
                })

                local ColorDisplay = CreateInstance("Frame", {
                    BackgroundColor3 = default,
                    BorderSizePixel = 0,
                    Size = UDim2.new(0, 28, 0, 28),
                    Position = UDim2.new(1, -40, 0.5, -14),
                    Parent = PickerFrame,
                    ZIndex = 9,
                })
                RoundCorners(ColorDisplay, 6)

                local selectedColor = default

                ColorDisplay.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        -- Simple color picker UI
                        local PickerOverlay = CreateInstance("Frame", {
                            BackgroundColor3 = Color3.fromRGB(0, 0, 0),
                            BackgroundTransparency = 0.5,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 1, 0),
                            Parent = Window,
                            ZIndex = 50,
                        })

                        local PickerBox = CreateInstance("ImageLabel", {
                            BackgroundColor3 = SelectedTheme.Main,
                            BorderSizePixel = 0,
                            Size = UDim2.new(0, 260, 0, 300),
                            Position = UDim2.new(0.5, -130, 0.5, -150),
                            Image = "rbxassetid://1316045217",
                            ImageColor3 = SelectedTheme.Main,
                            ScaleType = Enum.ScaleType.Slice,
                            SliceCenter = Rect.new(10, 10, 118, 118),
                            Parent = PickerOverlay,
                            ZIndex = 51,
                        })
                        RoundCorners(PickerBox, 10)

                        local PickerTitle = CreateInstance("TextLabel", {
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, -20, 0, 30),
                            Position = UDim2.new(0, 10, 0, 8),
                            Text = "Color Picker",
                            TextColor3 = SelectedTheme.Text,
                            Font = Enum.Font.GothamBold,
                            TextSize = 14,
                            Parent = PickerBox,
                            ZIndex = 52,
                        })

                        -- Preset colors
                        local presets = {
                            Color3.fromRGB(255, 255, 255),
                            Color3.fromRGB(0, 0, 0),
                            Color3.fromRGB(255, 0, 0),
                            Color3.fromRGB(0, 255, 0),
                            Color3.fromRGB(0, 0, 255),
                            Color3.fromRGB(255, 255, 0),
                            Color3.fromRGB(255, 0, 255),
                            Color3.fromRGB(0, 255, 255),
                            Color3.fromRGB(255, 128, 0),
                            Color3.fromRGB(128, 0, 255),
                            Color3.fromRGB(0, 255, 128),
                            Color3.fromRGB(255, 100, 100),
                            Color3.fromRGB(100, 255, 100),
                            Color3.fromRGB(100, 100, 255),
                            Color3.fromRGB(255, 200, 100),
                            Color3.fromRGB(200, 100, 255),
                            Color3.fromRGB(6, 182, 212), -- Accent
                            Color3.fromRGB(168, 85, 247), -- Purple
                            Color3.fromRGB(239, 68, 68), -- Red
                            Color3.fromRGB(34, 197, 94), -- Green
                            Color3.fromRGB(234, 179, 8), -- Yellow
                            Color3.fromRGB(59, 130, 246), -- Blue
                            Color3.fromRGB(236, 72, 153), -- Pink
                            Color3.fromRGB(251, 146, 60), -- Orange
                        }

                        local PresetGrid = CreateInstance("Frame", {
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, -20, 1, -50),
                            Position = UDim2.new(0, 10, 0, 42),
                            Parent = PickerBox,
                            ZIndex = 52,
                        })

                        local GridLayout = CreateInstance("UIGridLayout", {
                            CellSize = UDim2.new(0, 40, 0, 40),
                            CellPadding = UDim2.new(0, 6, 0, 6),
                            FillDirection = Enum.FillDirection.Horizontal,
                            StartCorner = Enum.StartCorner.TopLeft,
                            HorizontalAlignment = Enum.HorizontalAlignment.Left,
                            VerticalAlignment = Enum.VerticalAlignment.Top,
                            Parent = PresetGrid,
                        })

                        for _, color in ipairs(presets) do
                            local ColorBtn = CreateInstance("ImageButton", {
                                BackgroundColor3 = color,
                                BorderSizePixel = 0,
                                Size = UDim2.new(0, 40, 0, 40),
                                Parent = PresetGrid,
                                ZIndex = 53,
                            })
                            RoundCorners(ColorBtn, 6)

                            ColorBtn.MouseButton1Click:Connect(function()
                                selectedColor = color
                                ColorDisplay.BackgroundColor3 = color
                                pcall(callback, color)
                                PickerOverlay:Destroy()
                            end)
                        end

                        -- Close button
                        local ClosePicker = CreateInstance("TextButton", {
                            BackgroundTransparency = 1,
                            Size = UDim2.new(0, 20, 0, 20),
                            Position = UDim2.new(1, -25, 0, 8),
                            Text = "✕",
                            TextColor3 = SelectedTheme.TextDim,
                            Font = Enum.Font.Gotham,
                            TextSize = 14,
                            Parent = PickerBox,
                            ZIndex = 52,
                        })
                        ClosePicker.MouseButton1Click:Connect(function()
                            PickerOverlay:Destroy()
                        end)

                        PickerOverlay.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                -- Click outside to close (handled by overlay itself if direct child)
                            end
                        end)
                    end
                end)

                return {
                    Set = function(color)
                        selectedColor = color
                        ColorDisplay.BackgroundColor3 = color
                    end,
                    Get = function() return selectedColor end,
                }
            end

            table.insert(SectionObj.Frame, SectionContent)
            return SectionObj
        end

        -- Tab switching
        TabBtn.MouseButton1Click:Connect(function()
            if WindowObj.ActiveTab then
                WindowObj.ActiveTab.Page.Visible = false
                if WindowObj.ActiveTab.Indicator then
                    TweenService:Create(WindowObj.ActiveTab.Indicator, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
                end
                if WindowObj.ActiveTab.Label then
                    TweenService:Create(WindowObj.ActiveTab.Label, TweenInfo.new(0.3), {TextColor3 = SelectedTheme.TextDim}):Play()
                end
            end

            WindowObj.ActiveTab = TabObj
            TabObj.Page.Visible = true
            TweenService:Create(TabIndicator, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
            TweenService:Create(TabLabel, TweenInfo.new(0.3), {TextColor3 = SelectedTheme.Accent}):Play()
            TweenService:Create(TabBtn, TweenInfo.new(0.3), {
                BackgroundColor3 = SelectedTheme.Accent,
                BackgroundTransparency = 0.9,
            }):Play()
        end)

        TabObj.Button = TabBtn
        TabObj.Label = TabLabel
        TabObj.Indicator = TabIndicator

        table.insert(WindowObj.Tabs, TabObj)

        -- If first tab, auto-select
        if #WindowObj.Tabs == 1 then
            task.delay(0.1, function()
                TabBtn.MouseButton1Click:Fire()
            end)
        end

        return TabObj
    end

    -- Theme method
    function WindowObj:SetTheme(themeName)
        if Themes[themeName] then
            SelectedTheme = Themes[themeName]
        end
    end

    -- Destroy method
    function WindowObj:Destroy()
        ScreenGui:Destroy()
    end

    table.insert(WindowList, WindowObj)
    return WindowObj
end

-- ============================================================================
-- EXPORT
-- ============================================================================
return OrionLib
