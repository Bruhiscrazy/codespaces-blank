                    Position = UDim2.new(1, -72, 0, 8),
                    Text = tostring(default) .. suffix,
                    TextColor3 = SelectedTheme.Accent,
                    Font = Enum.Font.GothamBold,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = SliderFrame,
                    ZIndex = 8,
                })

                -- Slider bar
                local SliderBg = CreateInstance("Frame", {
                    BackgroundColor3 = SelectedTheme.ToggleOff,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, -24, 0, 4),
                    Position = UDim2.new(0, 12, 0, 38),
                    Parent = SliderFrame,
                    ZIndex = 8,
                })
                RoundCorners(SliderBg, 2)

                local SliderFill = CreateInstance("Frame", {
                    BackgroundColor3 = SelectedTheme.Accent,
                    BorderSizePixel = 0,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
                    Position = UDim2.new(0, 0, 0, 0),
                    Parent = SliderBg,
                    ZIndex = 9,
                })
                RoundCorners(SliderFill, 2)

                local SliderKnob = CreateInstance("Frame", {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    Size = UDim2.new(0, 14, 0, 14),
                    Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7),
                    Parent = SliderBg,
                    ZIndex = 10,
                })
                RoundCorners(SliderKnob, 7)

                local currentValue = default
                local sliding = false

                local function UpdateSlider(inputPos)
                    local pos = inputPos - SliderBg.AbsolutePosition.X
                    local size = SliderBg.AbsoluteSize.X
                    local ratio = math.clamp(pos / size, 0, 1)
                    local val = min + (max - min) * ratio
                    val = math.round(val / increment) * increment
                    val = math.clamp(val, min, max)
                    currentValue = val

                    local fillRatio = (val - min) / (max - min)
                    TweenService:Create(SliderFill, TweenInfo.new(0.1), {Size = UDim2.new(fillRatio, 0, 1, 0)}):Play()
                    TweenService:Create(SliderKnob, TweenInfo.new(0.1), {Position = UDim2.new(fillRatio, -7, 0.5, -7)}):Play()
                    SliderValue.Text = tostring(val) .. suffix
                    pcall(callback, val)
                end

                SliderBg.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true
                        UpdateSlider(input.Position)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input.Position)
                    end
                end)

                SliderFrame:Destroy()

                return {
                    Set = function(val)
                        val = math.clamp(val, min, max)
                        currentValue = val
                        local fillRatio = (val - min) / (max - min)
                        TweenService:Create(SliderFill, TweenInfo.new(0.2), {Size = UDim2.new(fillRatio, 0, 1, 0)}):Play()
                        TweenService:Create(SliderKnob, TweenInfo.new(0.2), {Position = UDim2.new(fillRatio, -7, 0.5, -7)}):Play()
                        SliderValue.Text = tostring(val) .. suffix
                    end,
                    Get = function() return currentValue end,
                }
            end

