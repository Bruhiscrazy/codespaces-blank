                OptBtn.MouseEnter:Connect(function()
                    Tween(OptBtn, 0.15, {TextColor3 = Theme.Accent})
                end)
                OptBtn.MouseLeave:Connect(function()
                    Tween(OptBtn, 0.15, {TextColor3 = Theme.TextDim})
                end)
                OptBtn.MouseButton1Click:Connect(function()
                    selected = opt
                    DropBtn.Text = "  " .. opt
                    open = false
                    Tween(DropFrame, 0.2, {Size = UDim2.new(1, 0, 0, closedH)})
                    Tween(Arrow, 0.2, {Rotation = 0})
                    callback(opt)
                end)
            end
            
            DropBtn.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    Tween(DropFrame, 0.25, {Size = UDim2.new(1, 0, 0, closedH + #options * optH + 4)})
                    Tween(Arrow, 0.2, {Rotation = 180})
                else
                    Tween(DropFrame, 0.25, {Size = UDim2.new(1, 0, 0, closedH)})
                    Tween(Arrow, 0.2, {Rotation = 0})
                end
            end)
        end
        
        function Tab:CreateTextbox(config)
            config = config or {}
            local name = config.Name or "Textbox"
            local placeholder = config.Placeholder or "Enter text..."
            local callback = config.Callback or function() end
            
            local TBFrame = Create("Frame", {
                Size = UDim2.new(1, 0, 0, CFG.DropdownHeight),
                BackgroundColor3 = Theme.Surface,
                BorderSizePixel = 0,
                Parent = TabContent
            })
            Corner(TBFrame, 6)
            
            Create("TextLabel", {
                Size = UDim2.new(1, -24, 0, 18),
                Position = UDim2.new(0, 12, 0, 6),
                BackgroundTransparency = 1,
                Text = name,
                TextColor3 = Theme.TextDim,
                TextSize = CFG.TextSize,
                Font = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = TBFrame
            })
            
            local tbH = DEVICE == "Mobile" and 28 or 24
            local TB = Create("TextBox", {
                Size = UDim2.new(1, -24, 0, tbH),
                Position = UDim2.new(0, 12, 0, 26),
                BackgroundColor3 = Theme.Surface3,
                Text = "",
                PlaceholderText = placeholder,
                TextColor3 = Theme.Text,
                PlaceholderColor3 = Theme.TextDim2,
                TextSize = 11,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                BorderSizePixel = 0,
                ClearTextOnFocus = false,
                Parent = TBFrame
            })
            Corner(TB, 4)
            Create("UIPadding", {PaddingLeft = UDim.new(0, 8), Parent = TB})
            
            local stroke = Stroke(TB, Theme.Border, 1)
            
            TB.Focused:Connect(function()
                Tween(stroke, 0.2, {Color = Theme.Accent})
            end)
            TB.FocusLost:Connect(function()
                Tween(stroke, 0.2, {Color = Theme.Border})
                callback(TB.Text)
            end)
        end
        
        function Tab:CreateKeybind(config)
            config = config or {}
            local name = config.Name or "Keybind"
            local default = config.Default or Enum.KeyCode.Q
            local callback = config.Callback or function() end
            local currentKey = default
            local listening = false
            
            local KFrame = Create("Frame", {
                Size = UDim2.new(1, 0, 0, CFG.ElementHeight),
                BackgroundColor3 = Theme.Surface,
                BorderSizePixel = 0,
                Parent = TabContent
            })
            Corner(KFrame, 6)
            
            Create("TextLabel", {
                Size = UDim2.new(1, -80, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text = name,
                TextColor3 = Theme.TextDim,
                TextSize = CFG.TextSize,
                Font = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = KFrame
            })
            
            local kbH = DEVICE == "Mobile" and 26 or 22
            local KeyBtn = Create("TextButton", {
                Size = UDim2.new(0, 60, 0, kbH),
                Position = UDim2.new(1, -68, 0.5, -kbH/2),
                BackgroundColor3 = Theme.Surface3,
                Text = currentKey.Name,
                TextColor3 = Theme.Text,
                TextSize = 11,
                Font = Enum.Font.GothamSemibold,
                BorderSizePixel = 0,
                Parent = KFrame
            })
            Corner(KeyBtn, 4)
            
            KeyBtn.MouseButton1Click:Connect(function()
                listening = true
                KeyBtn.Text = "..."
                KeyBtn.TextColor3 = Theme.Accent
            end)
            
            UserInputService.InputBegan:Connect(function(input, processed)
                if processed then return end
                if listening and input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode
                    KeyBtn.Text = currentKey.Name
                    KeyBtn.TextColor3 = Theme.Text
                    listening = false
                elseif input.KeyCode == currentKey then
                    callback()
                end
            end)
        end
        
        function Tab:CreateLabel(text)
            local Label = Create("TextLabel", {
                Size = UDim2.new(1, 0, 0, 24),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = Theme.TextDim,
                TextSize = CFG.TextSize,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = TabContent
            })
            Create("UIPadding", {PaddingLeft = UDim.new(0, 12), Parent = Label})
            return Label
        end
        
        return Tab
    end
    
    -- Floating Toggle Button (for mobile to reopen)
    if DEVICE == "Mobile" then
        local ToggleIcon = Create("TextButton", {
            Size = UDim2.new(0, 44, 0, 44),
            Position = UDim2.new(0, 10, 0, 80),
            BackgroundColor3 = Theme.Accent,
            Text = "N",
            TextColor3 = Color3.new(1, 1, 1),
            TextSize = 20,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = ScreenGui
        })
        Corner(ToggleIcon, 22)
        Stroke(ToggleIcon, Color3.new(1, 1, 1), 2)
        
        MakeDraggable(ToggleIcon, ToggleIcon)
        
        ToggleIcon.MouseButton1Click:Connect(function()
            Main.Visible = not Main.Visible
        end)
    end
    
    -- Open animation
    Main.Size = UDim2.new(0, 0, 0, 0)
    Tween(Main, 0.4, {Size = CFG.WindowSize}, Enum.EasingStyle.Back)
    
    -- Auto-resize on viewport change (rotation)
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        local newDevice = getDeviceType()
        if newDevice ~= DEVICE then
            -- Recommend reload, or auto-adjust
            Main.Size = UI_CONFIG[newDevice].WindowSize
        end
    end)
    
    return Window
end

return NovaUI
