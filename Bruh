        TextXAlignment = Enum.TextXAlignment.Left,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        Parent = notifFrame,
        ZIndex = 1001,
    })

    -- Accent line
    local accent = CreateInstance("Frame", {
        BackgroundColor3 = SelectedTheme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        Parent = notifFrame,
        ZIndex = 1002,
    })

    -- Animate in
    notifFrame.Position = UDim2.new(1, -370, 1, -20)
    TweenService:Create(notifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -370, 1, -100)
    }):Play()

    -- Timer bar
    local timerBar = CreateInstance("Frame", {
        BackgroundColor3 = SelectedTheme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        Parent = notifFrame,
        ZIndex = 1002,
    })
    TweenService:Create(timerBar, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 2)
    }):Play()

    -- Close
    task.delay(duration, function()
        TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.In), {
            Position = UDim2.new(1, -370, 1, 20),
            BackgroundTransparency = 1,
        }):Play()
        for _, v in ipairs(notifFrame:GetChildren()) do
            if v:IsA("TextLabel") or v:IsA("ImageLabel") or v:IsA("ImageLabel") then
                TweenService:Create(v, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
            end
        end
        task.delay(0.5, function()
            notifFrame:Destroy()
        end)
    end)
end

